generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── App Users (Admin / Viewer) ─────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("VIEWER") // ADMIN | VIEWER
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Developers / FTEs ──────────────────────────────────────────
model Developer {
  id                   String       @id @default(cuid())
  name                 String
  email                String       @unique
  jiraUserId           String       @unique
  role                 String       // ENG | PRODUCT | DESIGN
  monthlySalary        Float        @default(0)
  fringeBenefitRate    Float        @default(0.25)  // multiplier on salary
  stockCompAllocation  Float        @default(0)     // monthly stock comp
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tickets              JiraTicket[]
  payrollEntries       PayrollEntry[]
}

// ─── Payroll Imports (Pay Period Snapshots) ──────────────────
model PayrollImport {
  id               String   @id @default(cuid())
  label            String               // e.g. "Jan 15"
  payDate          DateTime             // the actual pay date
  year             Int
  fringeBenefitRate Float   @default(0.25)  // locked at import time from GlobalConfig
  createdAt        DateTime @default(now())

  entries   PayrollEntry[]

  @@unique([payDate])
  @@index([payDate])
}

model PayrollEntry {
  id              String   @id @default(cuid())
  grossSalary     Float
  sbcAmount       Float    @default(0)  // Stock-Based Compensation for this period
  createdAt       DateTime @default(now())

  developerId     String
  developer       Developer      @relation(fields: [developerId], references: [id])

  payrollImportId String
  payrollImport   PayrollImport  @relation(fields: [payrollImportId], references: [id], onDelete: Cascade)

  @@unique([developerId, payrollImportId])
  @@index([developerId])
  @@index([payrollImportId])
}

// ─── Projects (The Capitalizable Asset) ─────────────────────────
model Project {
  id                    String         @id @default(cuid())
  name                  String
  description           String?
  epicKey               String         @unique    // maps to Jira Epic key
  status                String         @default("PLANNING") // PLANNING | DEV | LIVE | RETIRED
  isCapitalizable       Boolean        @default(true)
  amortizationMonths    Int            @default(36)
  accumulatedCost       Float          @default(0)
  startingBalance       Float          @default(0) // legacy pre-app cost
  startingAmortization  Float          @default(0) // legacy accum amort
  startDate             DateTime?
  launchDate            DateTime?      // GA date — amort starts month after
  overrideReason        String?        // admin justification
  mgmtAuthorized        Boolean        @default(false)  // ASU 2025-06: management sign-off
  probableToComplete    Boolean        @default(false)  // ASU 2025-06: probable to complete
  budgetTarget          Float?         // monthly R&D budget target (for Budget vs. Actuals)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  tickets               JiraTicket[]
  journalEntries        JournalEntry[]
  amortOverrides        AmortizationOverride[]
}

// ─── Jira Tickets (Imported Activity) ───────────────────────────
model JiraTicket {
  id              String    @id @default(cuid())
  ticketId        String    @unique        // e.g. "PROJ-123"
  epicKey         String                    // links to Project.epicKey
  issueType       String                    // STORY | BUG | TASK
  summary         String
  storyPoints     Float     @default(0)
  resolutionDate  DateTime?
  fixVersion      String?
  customFields    Json?     // stores dynamic extra columns requested by the user
  importPeriod    String?   // e.g. "February 2026" — the accounting period this ticket was imported for
  capitalizedAmount   Float     @default(0)  // total $ capitalized on this ticket (accumulates across periods while open)
  amortizationMonths  Int       @default(36) // useful life inherited from project at cap time
  firstCapitalizedDate DateTime? // when this ticket first started accumulating capitalized cost
  createdAt       DateTime  @default(now())

  assigneeId      String?
  assignee        Developer? @relation(fields: [assigneeId], references: [id])

  projectId       String?
  project         Project?   @relation(fields: [projectId], references: [id])

  auditTrails     AuditTrail[]

  @@index([assigneeId])
  @@index([projectId])
  @@index([epicKey])
  @@index([resolutionDate])
  @@index([issueType])
  @@index([capitalizedAmount])
}

// ─── Accounting Periods ─────────────────────────────────────────
model AccountingPeriod {
  id                String         @id @default(cuid())
  month             Int            // 1-12
  year              Int
  status            String         @default("OPEN") // OPEN | CLOSED
  totalCapitalized  Float          @default(0)
  totalExpensed     Float          @default(0)
  totalAmortization Float          @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  journalEntries    JournalEntry[]

  @@unique([month, year])
}

// ─── Journal Entries ────────────────────────────────────────────
model JournalEntry {
  id            String   @id @default(cuid())
  entryType     String   // CAPITALIZATION | AMORTIZATION | EXPENSE
  debitAccount  String
  creditAccount String
  amount        Float
  description   String?
  createdAt     DateTime @default(now())

  periodId      String
  period        AccountingPeriod @relation(fields: [periodId], references: [id])

  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])

  auditTrails   AuditTrail[]

  @@index([periodId])
  @@index([projectId])
  @@index([entryType])
}

// ─── Audit Trail ────────────────────────────────────────────────
model AuditTrail {
  id              String   @id @default(cuid())
  allocatedAmount Float
  developerName   String
  ticketId        String   // display reference
  createdAt       DateTime @default(now())

  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  jiraTicketId    String
  jiraTicket      JiraTicket   @relation(fields: [jiraTicketId], references: [id])

  @@index([journalEntryId])
  @@index([jiraTicketId])
}

// ─── Global Configuration ───────────────────────────────────────
model GlobalConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String // human-readable label
}

// ─── GitHub Integration ─────────────────────────────────────────
model GitHubRepo {
  id        String   @id @default(cuid())
  owner     String                    // GitHub org or username
  name      String                    // repo name
  projectId String?                   // mapped project (null = unassigned)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  events    GitHubEvent[]

  @@unique([owner, name])
}

model GitHubEvent {
  id             String    @id @default(cuid())
  eventType      String                // PR | COMMIT
  githubId       String    @unique     // PR number or commit SHA (prefixed with repo)
  repoOwner      String
  repoName       String
  title          String
  author         String
  url            String?
  mergedAt       DateTime?
  classification String?               // CAPITALIZE | EXPENSE | UNCLASSIFIED
  projectId      String?               // matched project
  repoId         String?
  repo           GitHubRepo? @relation(fields: [repoId], references: [id])
  createdAt      DateTime @default(now())

  @@index([repoOwner, repoName])
  @@index([classification])
}

// ─── SOC 2 Type II Readiness ─────────────────────────────────────

// Control Library — one row per control across TSC criteria
model Soc2Control {
  id          String   @id @default(cuid())
  criterion   String   // CC6 | CC7 | CC2 | A1 | CC3
  controlId   String   @unique  // e.g. "CC6.1"
  title       String
  description String
  owner       String?  // team/person responsible
  frequency   String   @default("ANNUAL") // ANNUAL | QUARTERLY | MONTHLY | CONTINUOUS
  status      String   @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLIANT | AT_RISK
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evidence    Soc2Evidence[]
}

// Evidence Items — each piece of documentation/proof for a control
model Soc2Evidence {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String?  // link to doc, ticket, PR, etc
  reviewer    String?  // who verified this evidence
  reviewedAt  DateTime?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  controlId   String
  control     Soc2Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([controlId])
}

// Risk Register — likelihood × impact risk matrix
model Soc2RiskItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  criterion   String?  // which TSC/trust service area this risk touches
  likelihood  Int      @default(2)  // 1-4: Rare | Unlikely | Possible | Likely
  impact      Int      @default(2)  // 1-4: Low | Medium | High | Critical
  owner       String?
  mitigation  String?
  status      String   @default("OPEN") // OPEN | MITIGATED | ACCEPTED | CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Incident / Availability Log — for A1 availability criterion
model Soc2IncidentLog {
  id           String   @id @default(cuid())
  title        String
  incidentType String   @default("AVAILABILITY") // AVAILABILITY | SECURITY | CONFIDENTIALITY
  severity     String   @default("LOW")  // LOW | MEDIUM | HIGH | CRITICAL
  occurredAt   DateTime
  resolvedAt   DateTime?
  durationMins Int?     // downtime in minutes
  description  String?
  rootCause    String?
  remediation  String?
  reportedBy   String?
  isResolved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Amortization Overrides (User-Edited Schedule Rows) ─────────
model AmortizationOverride {
  id        String  @id @default(cuid())
  projectId String
  month     Int     // 1-12
  year      Int     // e.g. 2025
  charge    Float   // user-set monthly amortization charge
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, month, year])
  @@index([projectId])
}
